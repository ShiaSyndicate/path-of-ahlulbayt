{
  "env": {
    "browser": true,
    "es2021": true
  },
  "overrides": [
    {
      "files": ["scripts/**/*.js", "playwright.config.js", "tests/**/*.js"],
      "env": {
        "node": true,
        "es2021": true
      },
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "extends": [
    "eslint:recommended",
    "plugin:security/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "plugins": [
    "security"
  ],
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "security/detect-eval-with-expression": "error"
  }
}
