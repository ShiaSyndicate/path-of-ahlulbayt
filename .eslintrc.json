{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:security/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "plugins": [
    "security"
  ],
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "security/detect-eval-with-expression": "error"
  }
}
